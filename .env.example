# Hostname of the VPS (FQDN, must match rDNS)
RELAY_HOSTNAME=relay.example.com

# Domain(s) for which mail is relayed (comma-separated)
RELAY_DOMAINS=example.com,example.org

# IPv6 address of the Mailcow instance on the home network
MAILCOW_IPV6=2a01:xxxx:xxxx:xxxx::1

# Port on which Mailcow accepts SMTP (default: 25)
MAILCOW_PORT=25

# Maximum message size in bytes (default: 50 MB)
MESSAGE_SIZE_LIMIT=52428800

# Networks allowed for outbound relaying (optional, leave empty for inbound-only)
MYNETWORKS=127.0.0.0/8 [::1]/128

# Email address for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com
