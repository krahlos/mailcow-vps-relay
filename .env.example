## Relay Config

# Hostname of the VPS (FQDN, must match rDNS)
RELAY_HOSTNAME=relay.example.com

# Maximum message size in bytes (default: 50 MB)
MESSAGE_SIZE_LIMIT=52428800

# Networks allowed for outbound relaying (optional, leave empty for inbound-only)
MYNETWORKS=127.0.0.0/8 [::1]/128

## TLS / ACME

# Email address for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# DNS provider used for the DNS-01 ACME challenge.
# Supported: cloudflare | hetzner | infomaniak
# Only the matching *_API_TOKEN below needs to be set; leave the others empty.
# Do NOT commit real tokens; keep .env out of version control.
DNS_PROVIDER=

# Cloudflare API token. Scope: Zone:DNS:Edit on the zone that hosts RELAY_HOSTNAME.
CLOUDFLARE_API_TOKEN=

# Hetzner DNS Console API token.
HETZNER_API_TOKEN=

# Infomaniak API token. Scope: Domain on the product hosting RELAY_HOSTNAME.
INFOMANIAK_API_TOKEN=

## Relay Inbound

# Domain(s) for which mail is relayed (comma-separated)
RELAY_DOMAINS=example.com,example.org

# IPv6 address of the Mailcow instance on the home network
MAILCOW_IPV6=2a01:xxxx:xxxx:xxxx::1

# Port on which Mailcow accepts SMTP (default: 25)
MAILCOW_PORT=25

## Relay Outbound

# Credentials for Mailcow to authenticate when submitting outbound mail (ports 587/465)
SUBMISSION_USER=mailcow
# pragma: allowlist nextline secret
SUBMISSION_PASS=change-me
