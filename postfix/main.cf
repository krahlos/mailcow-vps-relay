# -------------------------------------------------------
# Basic configuration
# -------------------------------------------------------
myhostname = ${RELAY_HOSTNAME}
myorigin = ${RELAY_HOSTNAME}
mydomain = ${RELAY_HOSTNAME}

# No local delivery – pure relay
mydestination =
local_recipient_maps =
local_transport = error: local mail delivery is disabled

# Network interfaces (all)
inet_interfaces = all
inet_protocols = all

# -------------------------------------------------------
# Relay configuration
# -------------------------------------------------------
# Which domains are accepted?
relay_domains = ${RELAY_DOMAINS}

# Transport map: domain → target MTA
transport_maps = lmdb:/etc/postfix/transport

# Trusted networks (localhost only, no open relay!)
mynetworks = 127.0.0.0/8 [::1]/128

# -------------------------------------------------------
# Limits
# -------------------------------------------------------
message_size_limit = ${MESSAGE_SIZE_LIMIT}
mailbox_size_limit = 0

# -------------------------------------------------------
# TLS (inbound) — enabled at runtime if cert exists
# -------------------------------------------------------
##TLS## smtpd_tls_cert_file = /etc/letsencrypt/live/${RELAY_HOSTNAME}/fullchain.pem
##TLS## smtpd_tls_key_file  = /etc/letsencrypt/live/${RELAY_HOSTNAME}/privkey.pem
##TLS## smtpd_tls_security_level = may
##TLS## smtpd_tls_loglevel = 1

# -------------------------------------------------------
# TLS (outbound to Mailcow)
# -------------------------------------------------------
smtp_tls_security_level = may
smtp_tls_loglevel = 1

# -------------------------------------------------------
# SASL (used by submission/smtps listeners in master.cf)
# -------------------------------------------------------
smtpd_sasl_type = cyrus
smtpd_sasl_path = smtpd
smtpd_sasl_local_domain = $myhostname
smtpd_sasl_security_options = noanonymous
broken_sasl_auth_clients = yes

# -------------------------------------------------------
# Basic anti-spam (avoid generating backscatter)
# -------------------------------------------------------
smtpd_helo_required = yes
smtpd_helo_restrictions =
    check_helo_access texthash:/etc/postfix/helo_access,
    permit

smtpd_recipient_restrictions =
    permit_mynetworks,
    reject_unauth_destination

# Header modifications
header_checks = regexp:/etc/postfix/header_checks

# -------------------------------------------------------
# Logging — syslog (entrypoint starts syslogd → /var/log/postfix/mail.log)
# -------------------------------------------------------
